{
  "name": "kindness-taipei-mobile",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "run:ios": "expo run:ios",
    "run:android": "expo run:android",
    "simulator:create": "bash scripts/create-ios-simulator.sh",
    "simulator:open": "open -a Simulator",
    "pod:install": "cd ios && pod install",
    "pod:install:repo": "cd ios && pod install --repo-update",
    "build:ios": "eas build --platform ios --profile production",
    "build:android": "eas build --platform android --profile production",
    "build:android:apk": "eas build --platform android --profile preview"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "expo": "~52.0.0",
    "expo-asset": "~10.0.10",
    "expo-location": "~18.0.4",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-native": "0.76.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "eas-cli": "^14.0.0",
    "typescript": "~5.3.0"
  },
  "private": true
}
